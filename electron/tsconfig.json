{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "../dist-electron",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["bun-types", "node"]
  },
  "include": ["./**/*.ts"],
  "exclude": ["**/*.test.ts", "**/*.fixture.test.ts"]
}
